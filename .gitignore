# Please keep this file sorted (LC_COLLATE=C.UTF-8),
# grouped into the 3 categories below:
#  - general patterns (match in all directories)
#  - patterns to match files at the toplevel
#  - patterns to match files in subdirs

# general patterns
*.pyc
*.rpm

# toplevel (/...)
/Test*.html
/Test*.json
/Test*.log
/Test*.log.gz
/Test*.png
/*.whl
/bots
/cockpit-*.spec
/cockpit-*.tar.xz
/cockpit-navigator.spec
/dist/
/metafile.json
/package-lock.json
/pkg/
/node_modules/
/runtime-npm-modules.txt
/tmp/
/tools/

# subdirs (/subdir/...)
/packaging/arch/PKGBUILD
/packaging/debian/changelog
/po/*.pot
/po/LINGUAS
/test/common/
/test/images/
/test/static-code

# Build output — regenerated by `make`
dist/
node_modules/
*.log
pkg/
tmp/

# Editor noise
.vscode/
.idea/
*.swp
.DS_Store

# Cockpit test artifacts
test/common/
test/reference
bots/